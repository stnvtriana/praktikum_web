html, body{
    margin: 0;
    padding: 0;
}

p{
    text-align: justify;
}

#box{
    width: 1000px;
    height:auto;
    margin:auto;
}

#header{
    background-color: #dfd5d5;
    padding: 20px;
}

#menubar{
    background-color: #e4e4e4;
    margin: auto;
}
#menubar a{
    text-decoration : none;
    
}
#menubar a:hover{
    color : #db4f4f ;
}
.teksmenu{
    text-decoration: none;
}

#content{
    padding: 20px;
}

#footer{
    background-color: #999494;
    padding: 20px;
}
